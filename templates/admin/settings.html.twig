{% extends 'base.html.twig' %}

{% block title %}Configuration — FacturX{% endblock %}
{% block nav_admin %}active{% endblock %}

{% block body %}
<div class="space-y-8">

	{# ─── Header ─── #}
	<div data-aos="fade-up">
		<h2 class="text-2xl font-bold text-slate-800 tracking-tight">Configuration</h2>
		<p class="mt-1 text-sm text-slate-500">Paramètres globaux de génération Factur-X</p>
	</div>

	{# ─── Flash messages ─── #}
	{% for type, messages in app.flashes %}
		{% for message in messages %}
			<div class="rounded-xl px-4 py-3 text-sm font-medium
				{% if type == 'success' %}bg-emerald-50 text-emerald-700 border border-emerald-200{% endif %}
				{% if type == 'danger' %}bg-red-50 text-red-700 border border-red-200{% endif %}
			" data-aos="fade-up">
				{{ message }}
			</div>
		{% endfor %}
	{% endfor %}

	{# ─── Profil Factur-X ─── #}
	<form method="post" action="{{ path('admin_settings') }}">

		<div class="bg-white rounded-2xl shadow-sm border border-slate-200/60 overflow-hidden" data-aos="fade-up" data-aos-delay="100">
			<div class="px-6 py-5 border-b border-slate-100">
				<div class="flex items-center gap-3">
					<div class="w-10 h-10 rounded-xl bg-gradient-to-br from-violet-500 to-purple-600 flex items-center justify-center">
						<i data-lucide="settings-2" class="w-5 h-5 text-white"></i>
					</div>
					<div>
						<h3 class="text-lg font-semibold text-slate-800">Profil Factur-X</h3>
						<p class="text-xs text-slate-400">Détermine le niveau de détail du XML embarqué dans les PDF</p>
					</div>
				</div>
			</div>

			<div class="p-6 space-y-3">
				{% for key, profile in profiles %}
				<label class="flex items-start gap-4 p-4 rounded-xl border-2 cursor-pointer transition-all duration-200
					{% if currentProfile == key %}
						border-violet-500 bg-violet-50/50 shadow-sm
					{% else %}
						border-slate-200 hover:border-slate-300 hover:bg-slate-50/50
					{% endif %}
				">
					<input type="radio" name="facturx_profile" value="{{ key }}"
						{% if currentProfile == key %}checked{% endif %}
						class="mt-1 w-4 h-4 text-violet-600 focus:ring-violet-500 border-slate-300"
					>
					<div class="flex-1">
						<div class="flex items-center gap-2">
							<span class="font-semibold text-slate-800">{{ profile.label }}</span>
							{% if key == 'basic' %}
								<span class="px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider bg-emerald-100 text-emerald-700 rounded-full">Recommandé</span>
							{% endif %}
							{% if currentProfile == key %}
								<span class="px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider bg-violet-100 text-violet-700 rounded-full">Actif</span>
							{% endif %}
						</div>
						<p class="mt-1 text-sm text-slate-500">{{ profile.description }}</p>
						<code class="mt-2 block text-xs text-slate-400 font-mono">{{ profile.guideline }}</code>
					</div>
				</label>
				{% endfor %}
			</div>

			<div class="px-6 py-4 bg-slate-50 border-t border-slate-100 flex justify-end">
				<button type="submit" class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-violet-600 to-purple-600 text-white text-sm font-semibold rounded-xl shadow-sm hover:shadow-md hover:from-violet-700 hover:to-purple-700 transition-all duration-200">
					<i data-lucide="save" class="w-4 h-4"></i>
					Enregistrer
				</button>
			</div>
		</div>

	</form>

	{# ─── Info card ─── #}
	<div class="bg-amber-50 border border-amber-200 rounded-2xl p-5" data-aos="fade-up" data-aos-delay="200">
		<div class="flex gap-3">
			<div class="flex-shrink-0 mt-0.5">
				<i data-lucide="info" class="w-5 h-5 text-amber-600"></i>
			</div>
			<div class="text-sm text-amber-800 space-y-1">
				<p class="font-semibold">Quel profil choisir ?</p>
				<ul class="list-disc ml-4 space-y-1 text-amber-700">
					<li><strong>MINIMUM</strong> — Factures simples sans lignes de détail dans le XML</li>
					<li><strong>BASIC WL</strong> — Totaux et ventilation TVA, mais pas de lignes</li>
					<li><strong>BASIC</strong> — Lignes de facture complètes, conforme pour la plupart des PDP</li>
					<li><strong>EN16931</strong> — Profil complet norme européenne (allowances, charges, références)</li>
					<li><strong>EXTENDED</strong> — Données étendues, rarement nécessaire sauf exigences spécifiques</li>
				</ul>
				<p class="mt-2">Pour la réforme française de septembre 2026, le profil <strong>BASIC</strong> ou supérieur est requis.</p>
			</div>
		</div>
	</div>

</div>
{% endblock %}
