{% extends 'base.html.twig' %}
{% block title %}API Factur-X — PDF existant{% endblock %}
{% block body %}

<div class="mb-6">
    <h1 class="text-2xl font-bold">Intégration Factur-X dans un PDF existant</h1>
    <p class="text-gray-500 mt-1">Sélectionnez votre PDF — les données sont détectées automatiquement. Complétez ou corrigez si besoin, puis téléchargez.</p>
</div>

{# === ZONE STATUT === #}
<div id="status-box" class="hidden mb-6 p-4 rounded-lg border text-sm font-medium"></div>

<form id="apiForm" class="space-y-6">

    {# === UPLOAD PDF === #}
    <div class="bg-white rounded-xl shadow p-5 border-2 border-dashed border-indigo-300">
        <h2 class="text-lg font-semibold text-indigo-700 mb-3">PDF source</h2>
        <div class="flex items-center gap-4">
            <input type="file" id="pdfFile" accept="application/pdf"
                   class="flex-1 text-sm text-gray-600 file:mr-4 file:py-2 file:px-4 file:rounded file:border-0 file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 cursor-pointer"/>
            <div id="parse-status" class="hidden flex items-center gap-2 text-sm text-indigo-600 font-medium">
                <svg id="parse-spinner" class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
                </svg>
                <span id="parse-status-text">Analyse en cours…</span>
            </div>
        </div>
        <p class="text-xs text-gray-400 mt-2">Dès la sélection, les champs sont pré-remplis automatiquement. Les champs détectés apparaissent en vert.</p>
        <div id="parse-summary" class="hidden mt-3 text-xs bg-green-50 border border-green-200 rounded p-2 text-green-700"></div>
    </div>

    {# === FOURNISSEUR === #}
    <div class="bg-white rounded-xl shadow p-5">
        <h2 class="text-lg font-semibold text-indigo-700 mb-3">Fournisseur (vendeur)</h2>
        <div class="grid grid-cols-2 gap-3">
            <input data-field="fournisseur.nom"        type="text"  placeholder="Raison sociale *" class="border rounded p-2 w-full col-span-2" required/>
            <input data-field="fournisseur.siret"      type="text"  placeholder="SIRET (14 chiffres)" class="border rounded p-2 w-full"/>
            <input data-field="fournisseur.siren"      type="text"  placeholder="SIREN (9 chiffres)"  class="border rounded p-2 w-full"/>
            <input data-field="fournisseur.numeroTva"  type="text"  placeholder="N° TVA intracommunautaire" class="border rounded p-2 w-full"/>
            <input data-field="fournisseur.email"      type="email" placeholder="Email"               class="border rounded p-2 w-full"/>
            <input data-field="fournisseur.adresse"    type="text"  placeholder="Adresse"             class="border rounded p-2 w-full col-span-2"/>
            <input data-field="fournisseur.ville"      type="text"  placeholder="Ville"               class="border rounded p-2 w-full"/>
            <input data-field="fournisseur.codePostal" type="text"  placeholder="Code postal"         class="border rounded p-2 w-full"/>
            <select data-field="fournisseur.codePays" class="border rounded p-2 w-full">
                {% for code, label in countries %}<option value="{{ code }}"{{ code == 'FR' ? ' selected' : '' }}>{{ label }}</option>{% endfor %}
            </select>
        </div>
    </div>

    {# === ACHETEUR === #}
    <div class="bg-white rounded-xl shadow p-5">
        <h2 class="text-lg font-semibold text-indigo-700 mb-3">Acheteur</h2>
        <div class="grid grid-cols-2 gap-3">
            <input data-field="acheteur.nom"        type="text"  placeholder="Raison sociale *" class="border rounded p-2 w-full col-span-2" required/>
            <input data-field="acheteur.siren"      type="text"  placeholder="SIREN"            class="border rounded p-2 w-full"/>
            <input data-field="acheteur.numeroTva"  type="text"  placeholder="N° TVA"           class="border rounded p-2 w-full"/>
            <input data-field="acheteur.email"      type="email" placeholder="Email"            class="border rounded p-2 w-full"/>
            <input data-field="acheteur.adresse"    type="text"  placeholder="Adresse"          class="border rounded p-2 w-full col-span-2"/>
            <input data-field="acheteur.ville"      type="text"  placeholder="Ville"            class="border rounded p-2 w-full"/>
            <input data-field="acheteur.codePostal" type="text"  placeholder="Code postal"      class="border rounded p-2 w-full"/>
            <select data-field="acheteur.codePays" class="border rounded p-2 w-full">
                {% for code, label in countries %}<option value="{{ code }}"{{ code == 'FR' ? ' selected' : '' }}>{{ label }}</option>{% endfor %}
            </select>
        </div>
    </div>

    {# === INFOS FACTURE === #}
    <div class="bg-white rounded-xl shadow p-5">
        <h2 class="text-lg font-semibold text-indigo-700 mb-3">Informations de la facture</h2>
        <div class="grid grid-cols-2 gap-3">
            <input data-field="numeroFacture"    type="text" placeholder="Numéro de facture *"    class="border rounded p-2 w-full" required/>
            <input data-field="dateFacture"      type="date" class="border rounded p-2 w-full"     required/>
            <select data-field="devise" class="border rounded p-2 w-full">
                {% for code, label in currencies %}<option value="{{ code }}"{{ code == 'EUR' ? ' selected' : '' }}>{{ label }}</option>{% endfor %}
            </select>
            <input data-field="commandeAcheteur" type="text" placeholder="Référence commande"     class="border rounded p-2 w-full"/>
            <div>
                <label class="text-xs text-gray-500 block mb-1">Date d'échéance</label>
                <input data-field="dateEcheance" type="date" class="border rounded p-2 w-full"/>
            </div>
            <div>
                <label class="text-xs text-gray-500 block mb-1">Date de livraison</label>
                <input data-field="dateLivraison" type="date" class="border rounded p-2 w-full"/>
            </div>
            <textarea data-field="commentaire" placeholder="Commentaire (note libre)" class="border rounded p-2 w-full col-span-2" rows="2"></textarea>
        </div>
    </div>

    {# === LIGNES === #}
    <div class="bg-white rounded-xl shadow p-5">
        <h2 class="text-lg font-semibold text-indigo-700 mb-3">Lignes de facturation</h2>
        <div id="lignes-container" class="space-y-2 mb-3"></div>
        <template id="ligneTemplate">
            <div class="ligne-row grid grid-cols-10 gap-2 items-center bg-gray-50 p-2 rounded border">
                <input type="text"   placeholder="Désignation *"  class="col-span-3 border rounded px-2 py-1 text-sm" data-key="designation" required/>
                <input type="number" placeholder="Qté"            class="border rounded px-2 py-1 text-sm" data-key="quantite"      step="0.01" value="1"/>
                <input type="text"   placeholder="Unité"          class="border rounded px-2 py-1 text-sm" data-key="unite"         value="H87"/>
                <input type="number" placeholder="Prix HT"        class="border rounded px-2 py-1 text-sm" data-key="prixUnitaireHT" step="0.01"/>
                <input type="number" placeholder="TVA %"          class="border rounded px-2 py-1 text-sm" data-key="tauxTVA"       step="0.01" value="20"/>
                <input type="number" placeholder="HT calculé"     class="border rounded px-2 py-1 text-sm bg-gray-100" data-key="montantHT"  readonly/>
                <input type="number" placeholder="TTC calculé"    class="border rounded px-2 py-1 text-sm bg-gray-100" data-key="montantTTC" readonly/>
                <button type="button" class="removeLigne text-red-500 font-bold text-lg leading-none">&times;</button>
            </div>
        </template>
        <button type="button" id="addLigne" class="px-3 py-1 bg-indigo-600 text-white rounded text-sm">+ Ligne</button>

        <div class="mt-4 pt-3 border-t grid grid-cols-3 gap-4 text-right text-sm">
            <div><span class="text-gray-500">Total HT</span><br/><strong id="totalHT" class="text-base">0,00 €</strong></div>
            <div><span class="text-gray-500">Total TVA</span><br/><strong id="totalTVA" class="text-base">0,00 €</strong></div>
            <div><span class="text-gray-500">Total TTC</span><br/><strong id="totalTTC" class="text-lg text-indigo-700">0,00 €</strong></div>
        </div>
    </div>

    {# === REMISES / CHARGES === #}
    <div class="bg-white rounded-xl shadow p-5">
        <h2 class="text-lg font-semibold text-indigo-700 mb-3">Remises / Charges <span class="text-gray-400 font-normal text-sm">(optionnel)</span></h2>
        <div id="allow-container" class="space-y-2 mb-3"></div>
        <template id="allowTemplate">
            <div class="allow-row grid grid-cols-5 gap-2 items-center">
                <input type="number" step="0.01" placeholder="Montant HT"  class="border rounded p-2 text-sm" data-key="amount"/>
                <input type="number" step="0.01" placeholder="TVA %"       class="border rounded p-2 text-sm" data-key="taxRate"/>
                <select class="border rounded p-2 text-sm" data-key="isCharge">
                    <option value="false">Remise (–)</option>
                    <option value="true">Charge (+)</option>
                </select>
                <input type="text" placeholder="Libellé"                   class="border rounded p-2 text-sm" data-key="reason"/>
                <button type="button" class="removeAllow text-red-500 font-bold">&times;</button>
            </div>
        </template>
        <button type="button" id="addAllow" class="px-3 py-1 bg-indigo-600 text-white rounded text-sm">+ Ajouter</button>
    </div>

    {# === MOYENS DE PAIEMENT === #}
    <div class="bg-white rounded-xl shadow p-5">
        <h2 class="text-lg font-semibold text-indigo-700 mb-3">Moyens de paiement <span class="text-gray-400 font-normal text-sm">(optionnel)</span></h2>
        <div id="payment-container" class="space-y-2 mb-3"></div>
        <template id="payTemplate">
            <div class="pay-row grid grid-cols-3 gap-2 items-center">
                <select class="border rounded p-2 text-sm" data-key="code">
                    {% for code, label in payment_means %}<option value="{{ code }}">{{ code }} – {{ label }}</option>{% endfor %}
                </select>
                <input type="text" placeholder="IBAN ou information" class="border rounded p-2 text-sm" data-key="information"/>
                <button type="button" class="removePay text-red-500 font-bold">&times;</button>
            </div>
        </template>
        <button type="button" id="addPayment" class="px-3 py-1 bg-indigo-600 text-white rounded text-sm">+ Ajouter</button>
    </div>

    {# === ACTIONS === #}
    <div class="flex gap-4 pt-2 pb-10">
        <button type="button" id="btnEmbed"
                class="flex-1 py-3 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg font-bold text-lg shadow transition">
            <span id="btnEmbedLabel">Télécharger PDF Factur-X</span>
            <span id="spinnerEmbed" class="hidden ml-2">⏳</span>
        </button>
        <button type="button" id="btnXml"
                class="flex-1 py-3 bg-gray-600 hover:bg-gray-700 text-white rounded-lg font-bold text-lg shadow transition">
            <span id="btnXmlLabel">Télécharger XML seul</span>
            <span id="spinnerXml" class="hidden ml-2">⏳</span>
        </button>
    </div>

</form>

<script>
document.addEventListener('DOMContentLoaded', () => {

    // ── Parsing automatique au choix du PDF ───────────────────────────────
    const FIELD_LABELS = {
        'numeroFacture': 'Numéro de facture', 'dateFacture': 'Date',
        'fournisseur': 'Fournisseur', 'fournisseur.siret': 'SIRET',
        'fournisseur.tva': 'TVA fournisseur', 'acheteur': 'Acheteur',
        'paymentMeans': 'Moyen de paiement', 'lignes': 'Lignes',
    };

    function markField(el, detected) {
        if (!el) return;
        if (detected) {
            el.classList.add('border-green-400', 'bg-green-50');
            el.classList.remove('border-gray-300');
            el.setAttribute('data-autofilled', 'true');
        } else {
            el.classList.remove('border-green-400', 'bg-green-50');
            el.removeAttribute('data-autofilled');
        }
    }

    function setField(selector, value) {
        const el = document.querySelector(`[data-field="${selector}"]`);
        if (el && value != null && value !== '') {
            el.value = value;
            markField(el, true);
        }
    }

    function fillForm(data) {
        // Champs simples
        setField('numeroFacture',    data.numeroFacture);
        setField('dateFacture',      data.dateFacture);
        setField('devise',           data.devise);

        // Fournisseur
        if (data.fournisseur) {
            Object.entries(data.fournisseur).forEach(([k, v]) => setField('fournisseur.' + k, v));
        }
        // Acheteur
        if (data.acheteur) {
            Object.entries(data.acheteur).forEach(([k, v]) => setField('acheteur.' + k, v));
        }

        // Lignes — on vide et recrée
        if (data.lignes && data.lignes.length > 0) {
            lignesContainer.innerHTML = '';
            data.lignes.forEach(ligne => {
                addLigne();
                const row = lignesContainer.lastElementChild;
                row.querySelector('[data-key="designation"]').value    = ligne.designation || '';
                row.querySelector('[data-key="quantite"]').value       = ligne.quantite    || 1;
                row.querySelector('[data-key="prixUnitaireHT"]').value = ligne.prixUnitaireHT || '';
                row.querySelector('[data-key="tauxTVA"]').value        = ligne.tauxTVA     || 20;
                row.querySelector('[data-key="unite"]').value          = ligne.unite       || 'H87';
                recalcLigne(row);
                row.querySelectorAll('input').forEach(i => markField(i, true));
            });
        }

        // Moyens de paiement
        if (data.paymentMeans && data.paymentMeans.length > 0) {
            payContainer.innerHTML = '';
            data.paymentMeans.forEach(pm => {
                const frag = document.importNode(document.getElementById('payTemplate').content, true);
                frag.querySelector('.removePay').addEventListener('click', e => e.target.closest('.pay-row').remove());
                const div = frag.querySelector('.pay-row');
                payContainer.appendChild(frag);
                const codeEl = payContainer.lastElementChild.querySelector('[data-key="code"]');
                const infoEl = payContainer.lastElementChild.querySelector('[data-key="information"]');
                if (codeEl) { codeEl.value = pm.code || '30'; markField(codeEl, true); }
                if (infoEl) { infoEl.value = pm.information || ''; markField(infoEl, true); }
            });
        }

        // Résumé des champs détectés
        const detected = (data._detected || []).map(k => FIELD_LABELS[k] || k);
        if (detected.length > 0) {
            const summary = document.getElementById('parse-summary');
            summary.textContent = 'Détecté automatiquement : ' + detected.join(', ') + '.';
            summary.classList.remove('hidden');
        }
    }

    document.getElementById('pdfFile').addEventListener('change', async (e) => {
        if (!e.target.files.length) return;

        const parseStatus = document.getElementById('parse-status');
        const parseText   = document.getElementById('parse-status-text');
        parseStatus.classList.remove('hidden');
        parseText.textContent = 'Analyse en cours…';
        document.getElementById('parse-summary').classList.add('hidden');

        try {
            const form = new FormData();
            form.append('pdf', e.target.files[0]);

            const res  = await fetch('{{ path("api_facturx_parse") }}', { method: 'POST', body: form });
            const data = await res.json();

            if (!res.ok) throw new Error(data.error || 'Erreur serveur');

            fillForm(data);
            parseText.textContent = 'Données détectées';
            document.getElementById('parse-spinner').classList.add('hidden');

        } catch (err) {
            parseText.textContent = 'Détection échouée — remplissez manuellement';
            document.getElementById('parse-spinner').classList.add('hidden');
        }
    });

    // ── Lignes ────────────────────────────────────────────────────────────
    const lignesContainer = document.getElementById('lignes-container');
    const ligneTemplate   = document.getElementById('ligneTemplate').content;

    function recalcLigne(row) {
        const qte = parseFloat(row.querySelector('[data-key="quantite"]').value)      || 0;
        const pu  = parseFloat(row.querySelector('[data-key="prixUnitaireHT"]').value) || 0;
        const tva = parseFloat(row.querySelector('[data-key="tauxTVA"]').value)        || 0;
        const ht  = qte * pu;
        const ttc = ht * (1 + tva / 100);
        row.querySelector('[data-key="montantHT"]').value  = ht.toFixed(2);
        row.querySelector('[data-key="montantTTC"]').value = ttc.toFixed(2);
        recalcTotaux();
    }

    function recalcTotaux() {
        let ht = 0, tva = 0, ttc = 0;
        lignesContainer.querySelectorAll('.ligne-row').forEach(row => {
            const rowHT  = parseFloat(row.querySelector('[data-key="montantHT"]').value)  || 0;
            const rowTTC = parseFloat(row.querySelector('[data-key="montantTTC"]').value) || 0;
            ht  += rowHT;
            ttc += rowTTC;
            tva += rowTTC - rowHT;
        });
        document.getElementById('totalHT').textContent  = fmt(ht);
        document.getElementById('totalTVA').textContent = fmt(tva);
        document.getElementById('totalTTC').textContent = fmt(ttc);
    }

    function fmt(n) { return n.toLocaleString('fr-FR', {minimumFractionDigits: 2, maximumFractionDigits: 2}) + ' €'; }

    function addLigne() {
        const frag = document.importNode(ligneTemplate, true);
        const row  = frag.querySelector('.ligne-row');
        ['quantite','prixUnitaireHT','tauxTVA'].forEach(k => {
            row.querySelector(`[data-key="${k}"]`).addEventListener('input', () => recalcLigne(row));
        });
        row.querySelector('.removeLigne').addEventListener('click', () => { row.remove(); recalcTotaux(); });
        lignesContainer.appendChild(frag);
    }

    document.getElementById('addLigne').addEventListener('click', addLigne);
    addLigne(); // une ligne par défaut

    // ── Allowances ────────────────────────────────────────────────────────
    const allowContainer = document.getElementById('allow-container');
    document.getElementById('addAllow').addEventListener('click', () => {
        const frag = document.importNode(document.getElementById('allowTemplate').content, true);
        frag.querySelector('.removeAllow').addEventListener('click', e => e.target.closest('.allow-row').remove());
        allowContainer.appendChild(frag);
    });

    // ── Paiements ─────────────────────────────────────────────────────────
    const payContainer = document.getElementById('payment-container');
    document.getElementById('addPayment').addEventListener('click', () => {
        const frag = document.importNode(document.getElementById('payTemplate').content, true);
        frag.querySelector('.removePay').addEventListener('click', e => e.target.closest('.pay-row').remove());
        payContainer.appendChild(frag);
    });

    // ── Validation avant envoi ────────────────────────────────────────────
    function validateForm(invoice) {
        const errs = [];
        if (!invoice.numeroFacture)           errs.push('Numéro de facture manquant.');
        if (!invoice.dateFacture)             errs.push('Date de facture manquante.');
        if (!invoice.fournisseur?.nom)        errs.push('Nom du fournisseur manquant.');
        if (!invoice.fournisseur?.numeroTva && !invoice.fournisseur?.siren && !invoice.fournisseur?.siret)
                                              errs.push('Fournisseur : N° TVA, SIREN ou SIRET requis.');
        if (!invoice.acheteur?.nom)           errs.push("Nom de l'acheteur manquant.");
        if (!invoice.lignes?.length)          errs.push('Au moins une ligne de facturation est requise.');
        invoice.lignes?.forEach((l, i) => {
            const n = i + 1;
            if (!l.designation)              errs.push(`Ligne ${n} : désignation manquante.`);
            if (!l.quantite || l.quantite <= 0) errs.push(`Ligne ${n} : quantité invalide.`);
            if (l.prixUnitaireHT == null)    errs.push(`Ligne ${n} : prix unitaire HT manquant.`);
        });
        return errs;
    }

    // ── Collecte des données du formulaire ────────────────────────────────
    function collectInvoice() {
        function val(selector) {
            const el = document.querySelector(`[data-field="${selector}"]`);
            return el ? el.value.trim() : '';
        }

        function collectParty(prefix) {
            const obj = {};
            document.querySelectorAll(`[data-field^="${prefix}."]`).forEach(el => {
                const key = el.getAttribute('data-field').replace(prefix + '.', '');
                if (el.value.trim()) obj[key] = el.value.trim();
            });
            return obj;
        }

        const lignes = [];
        lignesContainer.querySelectorAll('.ligne-row').forEach(row => {
            lignes.push({
                designation:   row.querySelector('[data-key="designation"]').value.trim(),
                quantite:      parseFloat(row.querySelector('[data-key="quantite"]').value) || 0,
                unite:         row.querySelector('[data-key="unite"]').value.trim() || 'H87',
                prixUnitaireHT: parseFloat(row.querySelector('[data-key="prixUnitaireHT"]').value) || 0,
                tauxTVA:       parseFloat(row.querySelector('[data-key="tauxTVA"]').value) || 0,
            });
        });

        const allowances = [];
        allowContainer.querySelectorAll('.allow-row').forEach(row => {
            allowances.push({
                amount:    parseFloat(row.querySelector('[data-key="amount"]').value) || 0,
                taxRate:   parseFloat(row.querySelector('[data-key="taxRate"]').value) || 0,
                isCharge:  row.querySelector('[data-key="isCharge"]').value === 'true',
                reason:    row.querySelector('[data-key="reason"]').value.trim(),
            });
        });

        const paymentMeans = [];
        payContainer.querySelectorAll('.pay-row').forEach(row => {
            paymentMeans.push({
                code:        row.querySelector('[data-key="code"]').value,
                information: row.querySelector('[data-key="information"]').value.trim(),
            });
        });

        const invoice = {
            numeroFacture:    val('numeroFacture'),
            dateFacture:      val('dateFacture'),
            devise:           val('devise') || 'EUR',
            commandeAcheteur: val('commandeAcheteur') || undefined,
            dateEcheance:     val('dateEcheance')  || undefined,
            dateLivraison:    val('dateLivraison') || undefined,
            commentaire:      val('commentaire')   || undefined,
            fournisseur:      collectParty('fournisseur'),
            acheteur:         collectParty('acheteur'),
            lignes,
            allowances,
            paymentMeans,
        };

        // Nettoyer les clés undefined
        return JSON.parse(JSON.stringify(invoice));
    }

    // ── Affichage du statut ────────────────────────────────────────────────
    function showStatus(msg, type) {
        const box = document.getElementById('status-box');
        box.className = 'mb-6 p-4 rounded-lg border text-sm font-medium ' +
            (type === 'error'   ? 'bg-red-50 border-red-300 text-red-700' :
             type === 'success' ? 'bg-green-50 border-green-300 text-green-700' :
                                  'bg-blue-50 border-blue-300 text-blue-700');
        box.textContent = msg;
        box.classList.remove('hidden');
        box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    function setLoading(btnId, spinnerId, loading) {
        document.getElementById(btnId).disabled = loading;
        document.getElementById(spinnerId).classList.toggle('hidden', !loading);
    }

    // ── Téléchargement depuis un Blob ──────────────────────────────────────
    function downloadBlob(blob, filename) {
        const url = URL.createObjectURL(blob);
        const a   = document.createElement('a');
        a.href = url; a.download = filename;
        document.body.appendChild(a);
        a.click();
        setTimeout(() => { URL.revokeObjectURL(url); a.remove(); }, 1000);
    }

    // ── Bouton PDF Factur-X ───────────────────────────────────────────────
    document.getElementById('btnEmbed').addEventListener('click', async () => {
        const pdfInput = document.getElementById('pdfFile');
        if (!pdfInput.files.length) {
            showStatus('Veuillez sélectionner un fichier PDF source.', 'error'); return;
        }

        const invoice = collectInvoice();
        const errs = validateForm(invoice);
        if (errs.length) { showStatus('Champs manquants :\n• ' + errs.join('\n• '), 'error'); return; }

        setLoading('btnEmbed', 'spinnerEmbed', true);
        showStatus('Génération en cours…', 'info');

        try {
            const form = new FormData();
            form.append('pdf', pdfInput.files[0]);
            form.append('invoice', JSON.stringify(invoice));

            const res = await fetch('{{ path("api_facturx_embed") }}', { method: 'POST', body: form });

            if (!res.ok) {
                const err = await res.json().catch(() => ({ error: 'Erreur inconnue' }));
                throw new Error(err.error || `HTTP ${res.status}`);
            }

            const blob     = await res.blob();
            const filename = 'facture_' + (invoice.numeroFacture || 'fx').replace(/[^a-zA-Z0-9_\-]/g, '_') + '_facturx.pdf';
            downloadBlob(blob, filename);
            showStatus('PDF Factur-X généré et téléchargé avec succès.', 'success');

        } catch (e) {
            showStatus('Erreur : ' + e.message, 'error');
        } finally {
            setLoading('btnEmbed', 'spinnerEmbed', false);
        }
    });

    // ── Bouton XML seul ───────────────────────────────────────────────────
    document.getElementById('btnXml').addEventListener('click', async () => {
        const invoice = collectInvoice();
        const errs = validateForm(invoice);
        if (errs.length) { showStatus('Champs manquants :\n• ' + errs.join('\n• '), 'error'); return; }

        setLoading('btnXml', 'spinnerXml', true);
        showStatus('Génération du XML en cours…', 'info');

        try {
            const res = await fetch('{{ path("api_facturx_xml") }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(invoice),
            });

            if (!res.ok) {
                const err = await res.json().catch(() => ({ error: 'Erreur inconnue' }));
                throw new Error(err.error || `HTTP ${res.status}`);
            }

            const blob     = await res.blob();
            const filename = 'facture_' + (invoice.numeroFacture || 'fx').replace(/[^a-zA-Z0-9_\-]/g, '_') + '_fx.xml';
            downloadBlob(blob, filename);
            showStatus('XML Factur-X généré et téléchargé avec succès.', 'success');

        } catch (e) {
            showStatus('Erreur : ' + e.message, 'error');
        } finally {
            setLoading('btnXml', 'spinnerXml', false);
        }
    });

});
</script>
{% endblock %}
