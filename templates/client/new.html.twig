{% extends 'base.html.twig' %}

{% block title %}Nouveau Client{% endblock %}
{% block nav_client %}active{% endblock %}

{% block body %}
    <div class="flex items-center justify-between mb-8" data-aos="fade-down">
        <div>
            <h1 class="text-2xl font-bold text-slate-800">Ajouter un Client / Fournisseur</h1>
            <p class="text-sm text-slate-400 mt-1">Créez un nouveau contact pour vos factures</p>
        </div>
        <a href="{{ path('app_client_index') }}" class="btn btn-ghost">
            <i data-lucide="arrow-left" class="w-5 h-5"></i>
            Retour à la liste
        </a>
    </div>

    <div class="glass-card p-8 max-w-4xl mx-auto" data-aos="fade-up">
        {{ include('client/_form.html.twig') }}
    </div>
{% endblock %}
