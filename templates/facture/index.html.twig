{% extends 'base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}
{% block nav_index %}active{% endblock %}

{% block body %}

	{# ─── Header ─── #}
	<div class="flex items-center justify-between mb-8" data-aos="fade-down">
		<div>
			<h1 class="text-2xl font-bold text-slate-800">Tableau de bord</h1>
			<p class="text-sm text-slate-400 mt-1">Vos factures en un coup d'oeil</p>
		</div>
		<a href="{{ path('facture_new') }}" class="btn btn-primary btn-lg">
			<i data-lucide="plus" class="w-5 h-5"></i>
			Nouvelle facture
		</a>
	</div>

	{# ─── Stats Cards ─── #}
	{% set globalHT = 0 %}
	{% set globalTTC = 0 %}
	{% set nbFactures = factures|length %}
	{% for facture in factures %}
		{% for ligne in facture.lignes %}
			{% set globalHT = globalHT + ligne.montantHt %}
			{% set globalTTC = globalTTC + ligne.montantTtc %}
		{% endfor %}
	{% endfor %}

	<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
		<div class="stat-card" style="--accent-from:#6366f1;--accent-to:#8b5cf6" data-aos="fade-up" data-aos-delay="0">
			<div class="flex items-center justify-between mb-3">
				<div class="stat-icon bg-indigo-50 text-indigo-500">
					<i data-lucide="file-text" class="w-5 h-5"></i>
				</div>
			</div>
			<div class="stat-value counter" data-target="{{ nbFactures }}">0</div>
			<p class="text-xs text-slate-400 mt-2 font-medium">Factures totales</p>
		</div>

		<div class="stat-card" style="--accent-from:#3b82f6;--accent-to:#06b6d4" data-aos="fade-up" data-aos-delay="80">
			<div class="flex items-center justify-between mb-3">
				<div class="stat-icon bg-blue-50 text-blue-500">
					<i data-lucide="calculator" class="w-5 h-5"></i>
				</div>
			</div>
			<div class="stat-value text-xl">
				<span class="counter-decimal" data-target="{{ globalHT|number_format(2, '.', '') }}">0</span>
				<span class="text-sm font-medium text-slate-400 ml-1">EUR</span>
			</div>
			<p class="text-xs text-slate-400 mt-2 font-medium">Total HT</p>
		</div>

		<div class="stat-card" style="--accent-from:#10b981;--accent-to:#059669" data-aos="fade-up" data-aos-delay="160">
			<div class="flex items-center justify-between mb-3">
				<div class="stat-icon bg-emerald-50 text-emerald-500">
					<i data-lucide="trending-up" class="w-5 h-5"></i>
				</div>
			</div>
			<div class="stat-value text-xl">
				<span class="counter-decimal" data-target="{{ globalTTC|number_format(2, '.', '') }}">0</span>
				<span class="text-sm font-medium text-slate-400 ml-1">EUR</span>
			</div>
			<p class="text-xs text-slate-400 mt-2 font-medium">Total TTC</p>
		</div>

		<div class="stat-card" style="--accent-from:#f59e0b;--accent-to:#ef4444" data-aos="fade-up" data-aos-delay="240">
			<div class="flex items-center justify-between mb-3">
				<div class="stat-icon bg-amber-50 text-amber-500">
					<i data-lucide="clock" class="w-5 h-5"></i>
				</div>
			</div>
			<div class="stat-value counter" data-target="{{ factures|filter(f => f.dateEcheance and f.dateEcheance|date('U') > 'now'|date('U'))|length }}">0</div>
			<p class="text-xs text-slate-400 mt-2 font-medium">En attente</p>
		</div>
	</div>

	{# ─── Table ─── #}
	{% if factures is empty %}
		<div class="glass-card p-12" data-aos="fade-up">
			<div class="empty-state">
				<div class="empty-state-icon">
					<i data-lucide="inbox" class="w-9 h-9 text-indigo-400"></i>
				</div>
				<h3 class="text-lg font-semibold text-slate-700 mb-2">Aucune facture</h3>
				<p class="text-sm text-slate-400 mb-6">Commencez par creer votre premiere facture</p>
				<a href="{{ path('facture_new') }}" class="btn btn-primary">
					<i data-lucide="plus" class="w-4 h-4"></i> Creer une facture
				</a>
			</div>
		</div>
	{% else %}
		<div class="glass-card overflow-hidden" data-aos="fade-up" data-aos-delay="100">
			<div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
				<h2 class="text-sm font-semibold text-slate-700">
					{{ nbFactures }} facture{{ nbFactures > 1 ? 's' : '' }}
				</h2>
			</div>
			<div class="overflow-x-auto">
				<table class="modern-table">
					<thead>
						<tr>
							<th class="w-10"></th>
							<th>Numero</th>
							<th>Date</th>
							<th>Fournisseur</th>
							<th>Acheteur</th>
							<th class="text-right">Total HT</th>
							<th class="text-right">Total TTC</th>
							<th>Echeance</th>
							<th class="text-center">Statut Factur-X</th>
							<th class="text-right">Actions</th>
						</tr>
					</thead>
					<tbody>
						{% for facture in factures %}
							{% set totalHT = 0 %}
							{% set totalTTC = 0 %}
							{% for ligne in facture.lignes %}
								{% set totalHT = totalHT + ligne.montantHt %}
								{% set totalTTC = totalTTC + ligne.montantTtc %}
							{% endfor %}

							{# ─── Calculate Missing Values for Factur-X ─── #}
							{% set missing = [] %}
							
							{% if not facture.fournisseur %}
								{% set missing = missing|merge(['Fournisseur manquant']) %}
							{% else %}
								{% if facture.fournisseur.siren is empty %} {% set missing = missing|merge(['SIREN fournisseur absent']) %} {% endif %}
								{% if facture.fournisseur.siret is empty %} {% set missing = missing|merge(['SIRET fournisseur absent']) %} {% endif %}
								{% if facture.fournisseur.numeroTva is empty %} {% set missing = missing|merge(['Numéro TVA fournisseur absent']) %} {% endif %}
								{% if facture.fournisseur.adresse is empty or facture.fournisseur.ville is empty or facture.fournisseur.codePostal is empty or facture.fournisseur.codePays is empty %}
									{% set missing = missing|merge(['Adresse fournisseur incomplète']) %}
								{% endif %}
							{% endif %}

							{% if not facture.acheteur %}
								{% set missing = missing|merge(['Acheteur manquant']) %}
							{% else %}
								{% if facture.acheteur.siren is empty %} {% set missing = missing|merge(['SIREN acheteur absent']) %} {% endif %}
								{% if facture.acheteur.siret is empty %} {% set missing = missing|merge(['SIRET acheteur absent']) %} {% endif %}
								{% if facture.acheteur.numeroTva is empty %} {% set missing = missing|merge(['Numéro TVA acheteur absent']) %} {% endif %}
								{% if facture.acheteur.adresse is empty or facture.acheteur.ville is empty or facture.acheteur.codePostal is empty or facture.acheteur.codePays is empty %}
									{% set missing = missing|merge(['Adresse acheteur incomplète']) %}
								{% endif %}
							{% endif %}

							{% if facture.natureOperation is empty %}
								{% set missing = missing|merge(["Nature de l'opération non spécifiée"]) %}
							{% endif %}

							{% if facture.lignes is empty %}
								{% set missing = missing|merge(['Aucune ligne de facturation présente']) %}
							{% else %}
								{% set missingUnite = false %}
								{% for ligne in facture.lignes %}
									{% if ligne.unite is empty %}
										{% set missingUnite = true %}
									{% endif %}
								{% endfor %}
								{% if missingUnite %}
									{% set missing = missing|merge(['Unité (ex: H87, C62) manquante sur une ou plusieurs lignes']) %}
								{% endif %}
							{% endif %}

							<tr class="invoice-row" data-id="{{ facture.id }}">
								<td>
									<button class="expand-btn p-1 rounded-md hover:bg-slate-100 transition" data-target="detail-{{ facture.id }}">
										<i data-lucide="chevron-right" class="w-4 h-4 text-slate-400 expand-icon"></i>
									</button>
								</td>
								<td>
									<span class="font-semibold text-slate-800">{{ facture.numeroFacture }}</span>
								</td>
								<td class="text-slate-500">{{ facture.dateFacture|date('d/m/Y') }}</td>
								<td>
									<span class="inline-flex items-center gap-1.5">
										<span class="w-2 h-2 rounded-full bg-indigo-400"></span>
										{{ facture.fournisseur ? facture.fournisseur.nom : '-' }}
									</span>
								</td>
								<td>{{ facture.acheteur ? facture.acheteur.nom : '-' }}</td>
								<td class="text-right font-medium">{{ totalHT|number_format(2, ',', ' ') }} {{ facture.devise }}</td>
								<td class="text-right font-semibold text-slate-800">{{ totalTTC|number_format(2, ',', ' ') }} {{ facture.devise }}</td>
								<td>
									{% if facture.dateEcheance %}
										<span class="badge {{ facture.dateEcheance|date('U') < 'now'|date('U') ? 'bg-red-50 text-red-600' : 'bg-emerald-50 text-emerald-600' }}">
											{{ facture.dateEcheance|date('d/m/Y') }}
										</span>
									{% else %}
										<span class="text-slate-300">&mdash;</span>
									{% endif %}
								</td>
								<td class="text-center">
									{% if missing is empty %}
										<div class="inline-flex items-center gap-1 px-2.5 py-1 rounded-md bg-emerald-50 text-emerald-600 text-xs font-medium">
											<i data-lucide="check-circle" class="w-3.5 h-3.5"></i>
											Prêt
										</div>
									{% else %}
										<div class="group relative inline-block">
											<div class="inline-flex items-center gap-1 px-2.5 py-1 rounded-md bg-amber-50 text-amber-600 text-xs font-medium cursor-help">
												<i data-lucide="alert-triangle" class="w-3.5 h-3.5"></i>
												Incomplet
											</div>
											<div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 hidden group-hover:block w-64 bg-slate-800 text-white text-xs rounded-lg p-3 shadow-xl z-50">
												<p class="font-semibold mb-1 text-amber-400">Éléments obligatoires manquants :</p>
												<ul class="list-disc pl-4 text-left space-y-1">
													{% for m in missing %}
														<li>{{ m }}</li>
													{% endfor %}
												</ul>
											</div>
										</div>
									{% endif %}
								</td>
								<td>
									<div class="action-menu justify-end">
										<a href="{{ path('facture_show', {id: facture.id}) }}" class="btn btn-icon btn-ghost" title="Voir">
											<i data-lucide="eye" class="w-4 h-4"></i>
										</a>
										<a href="{{ path('facture_download_facturx', {id: facture.id}) }}" class="btn btn-icon btn-ghost" title="Telecharger FacturX" style="color:#06b6d4">
											<i data-lucide="download" class="w-4 h-4"></i>
										</a>
										<a href="{{ path('facture_edit', {id: facture.id}) }}" class="btn btn-icon btn-ghost" title="Modifier" style="color:#f59e0b">
											<i data-lucide="pencil" class="w-4 h-4"></i>
										</a>
										<form method="post" action="{{ path('facture_delete', {id: facture.id}) }}" onsubmit="return confirm('Confirmer la suppression ?');" class="inline">
											<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ facture.id) }}">
											<button type="submit" class="btn btn-icon btn-ghost" style="color:#ef4444" title="Supprimer">
												<i data-lucide="trash-2" class="w-4 h-4"></i>
											</button>
										</form>
									</div>
								</td>
							</tr>
							{# Detail row #}
							<tr>
								<td colspan="10" class="!p-0 !border-0">
									<div id="detail-{{ facture.id }}" class="detail-content px-6 bg-slate-50/50">
										
										{% if missing is not empty %}
											<div class="my-4 bg-amber-50/80 border border-amber-200 rounded-lg p-4 flex gap-3 shadow-sm">
												<div class="text-amber-500 mt-0.5">
													<i data-lucide="alert-circle" class="w-5 h-5"></i>
												</div>
												<div>
													<h4 class="text-sm font-semibold text-amber-800 mb-1">Action requise pour la génération Factur-X</h4>
													<p class="text-xs text-amber-700 mb-2">Les informations suivantes sont obligatoires pour générer une facture électronique conforme (Profil EN16931) :</p>
													<ul class="list-disc pl-4 text-xs tracking-wide text-amber-700 space-y-1">
														{% for m in missing %}
															<li>{{ m }}</li>
														{% endfor %}
													</ul>
													<div class="mt-3">
														<a href="{{ path('facture_edit', {id: facture.id}) }}" class="inline-flex items-center gap-1.5 text-xs font-semibold text-amber-600 hover:text-amber-700 bg-amber-100/50 px-3 py-1.5 rounded-md transition-colors">
															<i data-lucide="pencil" class="w-3.5 h-3.5"></i>
															Compléter la facture
														</a>
													</div>
												</div>
											</div>
										{% endif %}

										{% if facture.lignes is empty %}
											<p class="py-3 text-sm text-slate-400 italic">Aucune ligne</p>
										{% else %}
											<div class="py-3 space-y-1.5">
												{% for ligne in facture.lignes %}
													<div class="flex items-center gap-4 text-sm py-1.5 px-3 rounded-lg bg-white/60 border border-slate-100">
														<span class="font-medium text-slate-700 flex-1">{{ ligne.designation }}</span>
														<span class="text-slate-400">{{ ligne.quantite }} x {{ ligne.prixUnitaireHt|number_format(2, ',', ' ') }} {{ facture.devise }}</span>
														<span class="badge bg-indigo-50 text-indigo-600">TVA {{ ligne.tauxTva }}%</span>
														<span class="font-semibold text-slate-800 w-28 text-right">{{ ligne.montantTtc|number_format(2, ',', ' ') }} {{ facture.devise }}</span>
													</div>
												{% endfor %}
											</div>
										{% endif %}
									</div>
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</div>
	{% endif %}

{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', () => {
	lucide.createIcons();

	/* ─── Counters: show real values immediately as fallback ─── */
	document.querySelectorAll('.counter').forEach(el => {
		const target = parseInt(el.dataset.target) || 0;
		el.textContent = target;
	});
	document.querySelectorAll('.counter-decimal').forEach(el => {
		const target = parseFloat(el.dataset.target) || 0;
		el.textContent = target.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
	});

	/* ─── GSAP animations (graceful degradation) ─── */
	if (typeof gsap !== 'undefined') {
		document.querySelectorAll('.counter').forEach(el => {
			const target = parseInt(el.dataset.target) || 0;
			el.textContent = '0';
			gsap.to(el, {
				textContent: target,
				duration: 1.2,
				ease: 'power2.out',
				snap: { textContent: 1 },
				delay: 0.3,
			});
		});

		document.querySelectorAll('.counter-decimal').forEach(el => {
			const target = parseFloat(el.dataset.target) || 0;
			const obj = { val: 0 };
			gsap.to(obj, {
				val: target,
				duration: 1.5,
				ease: 'power2.out',
				delay: 0.3,
				onUpdate: () => {
					el.textContent = obj.val.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
				}
			});
		});

		/* ─── GSAP Stagger Table Rows ─── */
		gsap.fromTo('.invoice-row', 
			{ opacity: 0, x: -15 },
			{ opacity: 1, x: 0, duration: 0.4, stagger: 0.06, delay: 0.5, ease: 'power2.out', clearProps: 'all' }
		);
	}

	/* ─── Expand/Collapse Detail ─── */
	document.querySelectorAll('.expand-btn').forEach(btn => {
		btn.addEventListener('click', () => {
			const targetId = btn.dataset.target;
			const detail = document.getElementById(targetId);
			const icon = btn.querySelector('.expand-icon');
			const isOpen = detail.classList.contains('open');

			if (isOpen) {
				detail.classList.remove('open');
				icon.classList.remove('rotated');
			} else {
				detail.classList.add('open');
				icon.classList.add('rotated');
			}
		});
	});
});
</script>
{% endblock %}

