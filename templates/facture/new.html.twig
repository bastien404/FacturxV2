{% extends 'base.html.twig' %}
{% block title %}Nouvelle facture{% endblock %}
{% block nav_new %}active{% endblock %}

{% block body %}

	{# ─── Header ─── #}
	<div class="flex items-center justify-between mb-8" data-aos="fade-down">
		<div>
			<h1 class="text-2xl font-bold text-slate-800">Nouvelle facture</h1>
			<p class="text-sm text-slate-400 mt-1">Remplissez les informations ci-dessous</p>
		</div>
		<a href="{{ path('facture_index') }}" class="btn btn-ghost">
			<i data-lucide="arrow-left" class="w-4 h-4"></i> Retour
		</a>
	</div>

	<form method="post" id="factureForm">

		{# ═══ FOURNISSEUR ═══ #}
		<div class="form-section" data-aos="fade-up" data-aos-delay="0">
			<div class="form-section-title">
				<i data-lucide="building-2" class="w-5 h-5"></i> Fournisseur
			</div>
			<select id="select-fournisseur" name="fournisseur_id" class="form-input">
				<option value="">-- Selectionner un fournisseur --</option>
				{% for client in clients %}
					<option value="{{ client.id }}">{{ client.nom }} ({{ client.email }})</option>
				{% endfor %}
				<option value="new">+ Nouveau fournisseur</option>
			</select>
			<div id="fournisseur-fields" class="hidden mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
				<input type="text" name="nomFournisseur" placeholder="Nom" class="form-input">
				<input type="text" name="sirenFournisseur" placeholder="SIREN" class="form-input">
				<input type="text" name="siretFournisseur" placeholder="SIRET" class="form-input">
				<input type="text" name="tvaFournisseur" placeholder="Numero TVA" class="form-input">
				<input type="email" name="emailFournisseur" placeholder="Email" class="form-input">
				<input type="text" name="adresseFournisseur" placeholder="Adresse" class="form-input">
				<input type="text" name="villeFournisseur" placeholder="Ville" class="form-input">
				<input type="text" name="codePostalFournisseur" placeholder="Code Postal" class="form-input">
				<select name="codePaysFournisseur" class="form-input">
					<option value="">-- Pays --</option>
					{% for code, pays in countries %}
						<option value="{{ code }}">{{ pays }}</option>
					{% endfor %}
				</select>
			</div>
		</div>

		{# ═══ ACHETEUR ═══ #}
		<div class="form-section" data-aos="fade-up" data-aos-delay="60">
			<div class="form-section-title">
				<i data-lucide="user" class="w-5 h-5"></i> Acheteur
			</div>
			<select id="select-acheteur" name="acheteur_id" class="form-input">
				<option value="">-- Selectionner un acheteur --</option>
				{% for client in clients %}
					<option value="{{ client.id }}">{{ client.nom }} ({{ client.email }})</option>
				{% endfor %}
				<option value="new">+ Nouvel acheteur</option>
			</select>
			<div id="acheteur-fields" class="hidden mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
				<input type="text" name="nomAcheteur" placeholder="Nom" class="form-input">
				<input type="text" name="sirenAcheteur" placeholder="SIREN" class="form-input">
				<input type="text" name="tvaAcheteur" placeholder="Numero TVA" class="form-input">
				<input type="email" name="emailAcheteur" placeholder="Email" class="form-input">
				<input type="text" name="adresseAcheteur" placeholder="Adresse" class="form-input">
				<input type="text" name="villeAcheteur" placeholder="Ville" class="form-input">
				<input type="text" name="codePostalAcheteur" placeholder="Code Postal" class="form-input">
				<select name="codePaysAcheteur" class="form-input">
					<option value="">-- Pays --</option>
					{% for code, pays in countries %}
						<option value="{{ code }}">{{ pays }}</option>
					{% endfor %}
				</select>
			</div>
		</div>

		{# ═══ INFOS FACTURE ═══ #}
		<div class="form-section" data-aos="fade-up" data-aos-delay="120">
			<div class="form-section-title">
				<i data-lucide="file-text" class="w-5 h-5"></i> Informations de la facture
			</div>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-3">
				<input type="text" name="numeroFacture" placeholder="Numero de facture" class="form-input" required/>
				<input type="date" name="dateFacture" class="form-input" required/>
				<select name="devise" class="form-input" required>
					<option value="">-- Devise --</option>
					{% for code, label in currencies %}
						<option value="{{ code }}">{{ label }}</option>
					{% endfor %}
				</select>
				<input type="text" name="commandeAcheteur" placeholder="Commande acheteur" class="form-input"/>
				<div>
					<label class="text-xs text-slate-400 block mb-1">Date d'echeance</label>
					<input type="date" name="dateEcheance" class="form-input"/>
				</div>
				<div>
					<label class="text-xs text-slate-400 block mb-1">Date de livraison</label>
					<input type="date" name="dateLivraison" class="form-input"/>
				</div>
				<select name="modePaiement" class="form-input" required>
					{% for code, label in payment_means %}
						<option value="{{ code }}">{{ label }}</option>
					{% endfor %}
				</select>
				<input type="text" name="referencePaiement" placeholder="Reference paiement" class="form-input"/>
			</div>
		</div>

		{# ═══ LIGNES DE FACTURE ═══ #}
		<div class="form-section" data-aos="fade-up" data-aos-delay="180">
			<div class="form-section-title">
				<i data-lucide="list" class="w-5 h-5"></i> Lignes de facture
			</div>
			<div id="lignes-container" class="space-y-3 overflow-x-auto"></div>
			<template id="ligneTemplate">
				<div class="ligne-facture flex items-center gap-2 p-3 bg-slate-50/80 rounded-xl border border-slate-100" style="min-width:780px">
					<input type="text" name="__NAME__[designation]" placeholder="Designation" class="form-input" style="flex:2.5" required/>
					<input type="number" step="0.01" name="__NAME__[quantite]" placeholder="Qte" class="form-input" style="flex:1" required/>
					<input type="text" name="__NAME__[unite]" placeholder="Unite" class="form-input" style="flex:1"/>
					<input type="number" step="0.01" name="__NAME__[prixUnitaireHT]" placeholder="Prix HT" class="form-input" style="flex:1.2" required/>
					<input type="number" step="0.01" name="__NAME__[tauxTVA]" placeholder="TVA %" class="form-input" style="flex:1" value="20"/>
					<input type="number" readonly name="__NAME__[montantHT]" placeholder="HT" class="form-input" style="flex:1.2" readonly/>
					<input type="number" readonly name="__NAME__[montantTVA]" placeholder="TVA" class="form-input" style="flex:1.2" readonly/>
					<input type="number" readonly name="__NAME__[montantTTC]" placeholder="TTC" class="form-input" style="flex:1.2" readonly/>
					<button type="button" class="removeLigne btn-remove flex-shrink-0">&times;</button>
				</div>
			</template>
			<button type="button" id="addLigne" class="btn btn-primary btn-sm mt-3">
				<i data-lucide="plus" class="w-4 h-4"></i> Ajouter ligne
			</button>

			{# ─── Totals ─── #}
			<div class="totals-box mt-5 grid grid-cols-3 gap-4 text-right">
				<div>
					<span class="text-xs text-slate-400 block">Total HT</span>
					<span id="totalHT" class="total-value text-lg text-slate-700">0.00</span>
					<span class="text-sm text-slate-400">EUR</span>
				</div>
				<div>
					<span class="text-xs text-slate-400 block">Total TVA</span>
					<span id="totalTVA" class="total-value text-lg text-slate-700">0.00</span>
					<span class="text-sm text-slate-400">EUR</span>
				</div>
				<div>
					<span class="text-xs text-slate-400 block">Total TTC</span>
					<span id="totalTTC" class="total-value text-xl text-indigo-600">0.00</span>
					<span class="text-sm text-indigo-400">EUR</span>
				</div>
			</div>
		</div>

		{# ═══ ALLOWANCES / CHARGES ═══ #}
		<div class="form-section" data-aos="fade-up" data-aos-delay="240">
			<div class="form-section-title">
				<i data-lucide="percent" class="w-5 h-5"></i> Remises / Charges
				<span class="text-xs text-slate-400 font-normal ml-1">(optionnel)</span>
			</div>
			<div id="allowances-container" class="space-y-3 overflow-x-auto"></div>
			<template id="allowTemplate">
				<div class="allow-row flex items-center gap-2 p-3 bg-slate-50/80 rounded-xl border border-slate-100" style="min-width:500px">
					<input type="number" step="0.01" name="__NAME__[amount]" placeholder="Montant" class="form-input" style="flex:1.2"/>
					<input type="number" step="0.01" name="__NAME__[taxRate]" placeholder="Taux TVA (%)" class="form-input" style="flex:1"/>
					<select name="__NAME__[isCharge]" class="form-input" style="flex:1">
						<option value="0">Remise</option>
						<option value="1">Charge</option>
					</select>
					<input type="text" name="__NAME__[reason]" placeholder="Raison" class="form-input" style="flex:1.5"/>
					<button type="button" class="removeAllowance btn-remove flex-shrink-0">&times;</button>
				</div>
			</template>
			<button type="button" id="addAllowance" class="btn btn-primary btn-sm mt-3">
				<i data-lucide="plus" class="w-4 h-4"></i> Ajouter
			</button>
		</div>

		{# ═══ MOYENS DE PAIEMENT ═══ #}
		<div class="form-section" data-aos="fade-up" data-aos-delay="300">
			<div class="form-section-title">
				<i data-lucide="credit-card" class="w-5 h-5"></i> Moyens de paiement
				<span class="text-xs text-slate-400 font-normal ml-1">(optionnel)</span>
			</div>
			<div id="payments-container" class="space-y-3"></div>
			<template id="paymentTemplate">
				<div class="pay-row grid grid-cols-3 gap-2 items-center p-3 bg-slate-50/80 rounded-xl border border-slate-100">
					<select name="__NAME__[code]" class="form-input">
						{% for code, label in payment_means %}
							<option value="{{ code }}">{{ label }}</option>
						{% endfor %}
					</select>
					<input type="text" name="__NAME__[information]" placeholder="IBAN, info..." class="form-input"/>
					<button type="button" class="removePayment btn-remove">&times;</button>
				</div>
			</template>
			<button type="button" id="addPayment" class="btn btn-primary btn-sm mt-3">
				<i data-lucide="plus" class="w-4 h-4"></i> Moyen de paiement
			</button>
		</div>

		{# ═══ COMMENTAIRE ═══ #}
		<div class="form-section" data-aos="fade-up" data-aos-delay="360">
			<div class="form-section-title">
				<i data-lucide="message-square" class="w-5 h-5"></i> Commentaire
			</div>
			<textarea name="commentaire" rows="3" class="form-input" placeholder="Note libre..."></textarea>
		</div>

		{# ═══ SUBMIT ═══ #}
		<div class="flex gap-4 pt-2 pb-8" data-aos="fade-up" data-aos-delay="400">
			<button type="submit" class="btn btn-success btn-lg flex-1">
				<i data-lucide="check" class="w-5 h-5"></i> Creer la facture
			</button>
			<a href="{{ path('facture_index') }}" class="btn btn-ghost btn-lg">Annuler</a>
		</div>
	</form>

{% endblock %}

{% block javascripts %}
<script>
document.addEventListener("DOMContentLoaded", () => {
	lucide.createIcons();

	/* ─── Show/Hide new fournisseur/acheteur fields ─── */
	document.getElementById('select-fournisseur').addEventListener('change', e => {
		const fields = document.getElementById('fournisseur-fields');
		const show = e.target.value === 'new';
		fields.classList.toggle('hidden', !show);
		if (show) gsap.from(fields, { opacity: 0, y: -10, duration: 0.3, ease: 'power2.out' });
	});
	document.getElementById('select-acheteur').addEventListener('change', e => {
		const fields = document.getElementById('acheteur-fields');
		const show = e.target.value === 'new';
		fields.classList.toggle('hidden', !show);
		if (show) gsap.from(fields, { opacity: 0, y: -10, duration: 0.3, ease: 'power2.out' });
	});

	/* ─── Lignes ─── */
	const lignesContainer = document.getElementById("lignes-container");
	const ligneTemplate = document.getElementById("ligneTemplate").content;
	let ligneIndex = 0;

	function calculeLigne(ligne) {
		const qte = parseFloat(ligne.querySelector('[name$="[quantite]"]').value) || 0;
		const pu = parseFloat(ligne.querySelector('[name$="[prixUnitaireHT]"]').value) || 0;
		const tva = parseFloat(ligne.querySelector('[name$="[tauxTVA]"]').value) || 0;
		const ht = qte * pu;
		const montantTVA = (ht * tva) / 100;
		const ttc = ht + montantTVA;
		ligne.querySelector('[name$="[montantHT]"]').value = ht.toFixed(2);
		ligne.querySelector('[name$="[montantTVA]"]').value = montantTVA.toFixed(2);
		ligne.querySelector('[name$="[montantTTC]"]').value = ttc.toFixed(2);
		calculeTotaux();
	}

	function calculeTotaux() {
		let ht = 0, tva = 0, ttc = 0;
		document.querySelectorAll(".ligne-facture").forEach((l) => {
			ht += parseFloat(l.querySelector('[name$="[montantHT]"]').value) || 0;
			tva += parseFloat(l.querySelector('[name$="[montantTVA]"]').value) || 0;
			ttc += parseFloat(l.querySelector('[name$="[montantTTC]"]').value) || 0;
		});

		/* Animate totals with GSAP */
		gsap.to('#totalHT', { textContent: ht.toFixed(2), duration: 0.3, snap: { textContent: 0.01 } });
		gsap.to('#totalTVA', { textContent: tva.toFixed(2), duration: 0.3, snap: { textContent: 0.01 } });
		gsap.to('#totalTTC', { textContent: ttc.toFixed(2), duration: 0.3, snap: { textContent: 0.01 } });
	}

	function addLigne() {
		const fragment = document.importNode(ligneTemplate, true);
		fragment.querySelectorAll("input, select").forEach((input) => {
			input.name = input.name.replace("__NAME__", "lignes[" + ligneIndex + "]");
			if (["quantite", "prixUnitaireHT", "tauxTVA"].some((k) => input.name.includes(k))) {
				input.addEventListener("input", (e) => calculeLigne(e.target.closest(".ligne-facture")));
			}
		});
		fragment.querySelector(".removeLigne").addEventListener("click", (e) => {
			const row = e.target.closest(".ligne-facture");
			gsap.to(row, { opacity: 0, height: 0, duration: 0.25, ease: 'power2.in', onComplete: () => { row.remove(); calculeTotaux(); } });
		});
		lignesContainer.appendChild(fragment);
		/* Animate new line in */
		const newRow = lignesContainer.lastElementChild;
		gsap.from(newRow, { opacity: 0, y: -10, duration: 0.3, ease: 'power2.out' });
		ligneIndex++;
	}

	document.getElementById("addLigne").addEventListener("click", addLigne);
	addLigne();

	/* ─── Allowances / Charges ─── */
	const allowContainer = document.getElementById("allowances-container");
	const allowTemplate = document.getElementById("allowTemplate").content;
	let allowIndex = 0;
	document.getElementById("addAllowance").addEventListener("click", () => {
		const fragment = document.importNode(allowTemplate, true);
		fragment.querySelectorAll("input, select").forEach((input) => {
			input.name = input.name.replace("__NAME__", "allowances[" + allowIndex + "]");
		});
		fragment.querySelector(".removeAllowance").addEventListener("click", (e) => {
			const row = e.target.closest(".allow-row");
			gsap.to(row, { opacity: 0, height: 0, duration: 0.25, onComplete: () => row.remove() });
		});
		allowContainer.appendChild(fragment);
		gsap.from(allowContainer.lastElementChild, { opacity: 0, y: -10, duration: 0.3 });
		allowIndex++;
	});

	/* ─── Payments ─── */
	const payContainer = document.getElementById("payments-container");
	const payTemplate = document.getElementById("paymentTemplate").content;
	let payIndex = 0;
	document.getElementById("addPayment").addEventListener("click", () => {
		const fragment = document.importNode(payTemplate, true);
		fragment.querySelectorAll("input, select").forEach((input) => {
			input.name = input.name.replace("__NAME__", "paymentMeans[" + payIndex + "]");
		});
		fragment.querySelector(".removePayment").addEventListener("click", (e) => {
			const row = e.target.closest(".pay-row");
			gsap.to(row, { opacity: 0, height: 0, duration: 0.25, onComplete: () => row.remove() });
		});
		payContainer.appendChild(fragment);
		gsap.from(payContainer.lastElementChild, { opacity: 0, y: -10, duration: 0.3 });
		payIndex++;
	});

	/* Re-init icons for dynamically added content */
	lucide.createIcons();
});
</script>
{% endblock %}
